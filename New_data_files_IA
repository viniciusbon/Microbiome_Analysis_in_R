# ── Helper: salvar ggplot com segurança ──────────────────────────────────────

safe_ggsave <- function(path, plot_obj, w, h, dpi = DPI) {
  ok <- tryCatch({
    ggsave(path, plot = plot_obj, width = w, height = h,
           dpi = dpi, bg = "white")
    TRUE
  }, error = function(e) {
    cat(sprintf("  ✘ %s — %s\n", basename(path), conditionMessage(e)))
    FALSE
  })
  
  fsize <- if (ok && file.exists(path)) {
    fs <- file.info(path)$size
    if (fs > 1e6) sprintf("%.1f MB", fs / 1e6) else sprintf("%.0f KB", fs / 1e3)
  } else { "—" }
  
  if (ok) cat(sprintf("  ✔ %-45s  %s\n", basename(path), fsize))
  
  export_log <<- bind_rows(export_log, tibble(
    file = path, type = "plot", status = if (ok) "✔" else "✘", size = fsize
  ))
  invisible(ok)
}

# ── Helper: salvar ComplexHeatmap (device base R) ────────────────────────────

safe_heatmap_png <- function(path, ht_obj, w, h, dpi = DPI) {
  ok <- tryCatch({
    png(path, width = w, height = h, units = "in", res = dpi)
    draw(ht_obj, merge_legend = TRUE)
    dev.off()
    TRUE
  }, error = function(e) {
    try(dev.off(), silent = TRUE)
    cat(sprintf("  ✘ %s — %s\n", basename(path), conditionMessage(e)))
    FALSE
  })
  
  fsize <- if (ok && file.exists(path)) {
    fs <- file.info(path)$size
    if (fs > 1e6) sprintf("%.1f MB", fs / 1e6) else sprintf("%.0f KB", fs / 1e3)
  } else { "—" }
  
  if (ok) cat(sprintf("  ✔ %-45s  %s\n", basename(path), fsize))
  
  export_log <<- bind_rows(export_log, tibble(
    file = path, type = "plot", status = if (ok) "✔" else "✘", size = fsize
  ))
  invisible(ok)
}

# ── Helper: salvar tabela CSV ────────────────────────────────────────────────

safe_csv <- function(df, path) {
  ok <- tryCatch({
    write_csv(df, path)
    TRUE
  }, error = function(e) {
    cat(sprintf("  ✘ %s — %s\n", basename(path), conditionMessage(e)))
    FALSE
  })
  
  fsize <- if (ok && file.exists(path)) {
    sprintf("%d rows × %d cols", nrow(df), ncol(df))
  } else { "—" }
  
  if (ok) cat(sprintf("  ✔ %-45s  %s\n", basename(path), fsize))
  
  export_log <<- bind_rows(export_log, tibble(
    file = path, type = "table", status = if (ok) "✔" else "✘", size = fsize
  ))
  invisible(ok)
}

# ── Helper: salvar RDS ───────────────────────────────────────────────────────

safe_rds <- function(obj, path) {
  ok <- tryCatch({ saveRDS(obj, path); TRUE },
                 error = function(e) { FALSE })
  
  fsize <- if (ok && file.exists(path)) {
    fs <- file.info(path)$size
    if (fs > 1e6) sprintf("%.1f MB", fs / 1e6) else sprintf("%.0f KB", fs / 1e3)
  } else { "—" }
  
  status <- if (ok) "✔" else "✘"
  cat(sprintf("  %s %-45s  %s\n", status, basename(path), fsize))
  
  export_log <<- bind_rows(export_log, tibble(
    file = path, type = "rds", status = status, size = fsize
  ))
  invisible(ok)
}

