# ─────────────────────────────────────────────────────────────────────────────
# 6.5 Sequencing depth check — before rarefaction
# ─────────────────────────────────────────────────────────────────────────────
# Note: Depth is calculated directly from the clean count matrix (tax_counts_final_qc),
# bypassing the need for a phyloseq object at this specific QC stage.

# Calculate total reads per sample (excluding the 7 taxonomy columns)
depths <- colSums(tax_counts_final_qc %>% select(-all_of(tax_cols)))

depth_df <- data.frame(
  sample_clean = names(depths),
  Depth        = depths
) %>%
  left_join(
    metadata %>% select(sample_clean, treatment),
    by = "sample_clean"
  ) %>%
  arrange(Depth)

# Validate join
if (any(is.na(depth_df$treatment))) {
  warning("Depth join failed for some samples — check sample IDs!")
  print(depth_df %>% filter(is.na(treatment)))
} else {
  cat("✔ Depth join OK — all samples matched to metadata\n")
}

rare_depth <- min(depth_df$Depth)

cat(sprintf(
  "Rarefaction depth (minimum): %d  |  Max: %d  |  Median: %.0f\n",
  rare_depth, max(depth_df$Depth), median(depth_df$Depth)
))

p_depth <- ggplot(depth_df,
                  aes(x = reorder(sample_clean, Depth),
                      y = Depth,
                      fill = treatment)) +
  geom_col(alpha = 0.85) +
  geom_hline(yintercept = rare_depth,
             color = "darkred", linetype = "dashed", linewidth = 0.8) +
  annotate("text",
           x     = 1,
           y     = rare_depth,
           label = sprintf("Rarefaction depth: %d", rare_depth),
           vjust = -0.5, hjust = 0, color = "darkred", size = 3.5) +
  scale_fill_brewer(palette = "Set1") +
  labs(
    title    = "Sequencing Depth per Sample",
    subtitle = "Red dashed line = rarefaction threshold (minimum depth)",
    x        = "Sample",
    y        = "Read Count",
    fill     = "Treatment"
  ) +
  theme_minimal(base_size = 12) +
  theme(
    plot.title    = element_text(face = "bold"),
    plot.subtitle = element_text(color = "grey40"),
    axis.text.x   = element_text(angle = 90, hjust = 1, vjust = 0.5)
  )

print(p_depth)
