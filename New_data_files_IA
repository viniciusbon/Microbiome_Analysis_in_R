cat(sprintf("  q < 0.10           : %d\n", n_sig_10))
cat(sprintf("  q < 0.05           : %d\n", n_sig_05))
cat(sprintf("  Enriquecidas %-10s: %d\n", comparison_group, n_enr_comp))
cat(sprintf("  Enriquecidas %-10s: %d\n", ref_group, n_enr_ref))

