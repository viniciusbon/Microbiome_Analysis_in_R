plot_ord_stats <- function(scores_df, x_col, y_col,
                           x_label, y_label,
                           title, subtitle,
                           stats_text = NULL) {
  
  p <- ggplot(scores_df,
              aes(x     = .data[[x_col]],
                  y     = .data[[y_col]],
                  color = treatment,
                  label = sample_id)) +
    geom_point(size = 3.5, alpha = 0.85) +
    geom_text_repel(
      size          = 2.8,
      max.overlaps  = 30,
      show.legend   = FALSE,
      segment.color = "grey60"
    ) +
    stat_ellipse(
      aes(group = treatment),
      type      = "norm",
      linetype  = "dashed",
      alpha     = 0.6,
      linewidth = 0.7
    ) +
    scale_color_manual(values = group_colors) +
    labs(
      title    = title,
      subtitle = subtitle,
      x        = x_label,
      y        = y_label,
      color    = "Treatment"
    ) +
    theme_bw(base_size = 13) +
    theme(
      plot.title      = element_text(face = "bold"),
      plot.subtitle   = element_text(color = "grey40", size = 10),
      legend.position = "right"
    )
  
  if (!is.null(stats_text)) {
    p <- p +
      annotate(
        "label",
        x          = Inf,
        y          = -Inf,
        label      = stats_text,
        hjust      = 1.03,
        vjust      = -0.15,
        size       = 3.0,
        color      = "black",
        fill       = "white",
        alpha      = 0.88,
        label.size = 0.35,
        family     = "mono",
        fontface   = "plain"
      )
  }
  
  p
}

