  var_pcoa <- round(eig[eig > 0] / sum(eig[eig > 0]) * 100, 1)
  
  pcoa_df <- as.data.frame(pcoa_res$vectors[, 1:2]) %>%
    setNames(c("Axis1", "Axis2")) %>%
    rownames_to_column("sample_id") %>%
    mutate(sample_id = fix_id(sample_id)) %>%
    left_join(
      metadata_filtrado %>% select(sample_id, treatment),
      by = "sample_id"
    )
  
  annot <- stats_by_dist[[dist_name]]$annot_text
  
  pcoa_subtitle <- if (!is.na(rare_depth)) {
    sprintf("Rarefied to %s reads | Age %d d | 999 permutations",
            format(rare_depth, big.mark = ","), target_age)
  } else {
    sprintf("Non-rarefied | Age %d d | 999 permutations", target_age)
  }
  
  p <- plot_ord_stats(
    scores_df  = pcoa_df,
    x_col      = "Axis1",
    y_col      = "Axis2",
    x_label    = sprintf("PCoA Axis 1 (%.1f%%)", var_pcoa[1]),
    y_label    = sprintf("PCoA Axis 2 (%.1f%%)", var_pcoa[2]),
    title      = sprintf("PCoA — %s Distance", dist_name),
    subtitle   = pcoa_subtitle,
    stats_text = annot
  )
  
  pcoa_plots[[dist_name]] <- p
  print(p)
}

