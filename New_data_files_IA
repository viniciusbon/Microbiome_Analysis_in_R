# ==============================================================================
# 8.8  Homogeneidade de dispersão — betadisper (pressuposição do PERMANOVA)
# ==============================================================================

betadisp_results <- map_dfr(names(dist_list), function(dist_name) {
  
  beta_d <- betadisper(dist_list[[dist_name]], group = meta_beta$treatment)
  set.seed(42)
  perm_d <- permutest(beta_d, permutations = 999)
  
  tibble(
    Distance = dist_name,
    F_stat   = round(perm_d$tab[1, "F"],      4),
    p_value  = round(perm_d$tab[1, "Pr(>F)"], 4),
    Result   = case_when(
      perm_d$tab[1, "Pr(>F)"] < 0.05 ~
        "⚠ Dispersão desigual — PERMANOVA pode refletir spread, não location",
      TRUE ~
        "✔ Dispersão homogênea — PERMANOVA confiável"
    )
  )
})

