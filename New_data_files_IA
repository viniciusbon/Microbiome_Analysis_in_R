# Função simplificada e robusta para criar Phyloseq
create_phyloseq_object <- function(tax_data, meta_data) {
  
  # 1. Matriz de Abundância (OTU/ASV)
  otu_wide <- tax_data %>%
    select(sample_id, feature, count) %>%
    group_by(sample_id, feature) %>%
    summarise(count = sum(count, na.rm = TRUE), .groups = "drop") %>% 
    pivot_wider(names_from = sample_id, values_from = count, values_fill = 0) %>%
    column_to_rownames("feature") %>%
    as.matrix()
  
  # 2. Tabela de Taxonomia (Separando os níveis taxonômicos)
  tax_table_matrix <- tax_data %>%
    select(feature) %>%
    distinct() %>%
    separate(feature, into = c("Kingdom", "Phylum", "Class", "Order", "Family", "Genus", "Species"), 
             sep = "\\|", fill = "right", remove = FALSE) %>%
    column_to_rownames("feature") %>%
    as.matrix()
  
  # 3. Tabela de Metadados
  sample_info <- meta_data %>%
    column_to_rownames("sample_id") %>%
    as.data.frame()
  
  # 4. Criar o objeto combinando os 3 elementos
  physeq <- phyloseq(
    otu_table(otu_wide, taxa_are_rows = TRUE),
    tax_table(tax_table_matrix),
    sample_data(sample_info)
  )
  
  return(physeq)
}

