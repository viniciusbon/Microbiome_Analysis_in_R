# Helper: reverter mangling que o R/phyloseq faz nos sample names
# make.names() adiciona "X" em IDs numéricos e troca "-" por "."
fix_id <- function(x) {
  x %>%
    str_remove("^X") %>%
    str_replace_all("\\.", "-")
}

