# ── 9.1a  Extrair nível de espécie ──────────────────────────────────────────

species_maaslin <- dados_tax_filtrado %>%
  select(sample_id, feature, count) %>%
  separate(
    feature,
    into  = c("Kingdom", "Phylum", "Class", "Order",
              "Family", "Genus", "Species"),
    sep   = "\\|",
    fill  = "right",
    extra = "drop",
    remove = FALSE
  ) %>%
  mutate(across(Kingdom:Species, ~ str_remove(.x, "^[a-zA-Z]+__"))) %>%
  filter(!is.na(Species), Species != "", Species != "NA") %>%
  # Agregar por Genus|Species (evitar duplicatas de lineagem)
  mutate(tax_id = paste(Genus, Species, sep = "|")) %>%
  group_by(sample_id, tax_id) %>%
  summarise(count = sum(count, na.rm = TRUE), .groups = "drop")

cat(sprintf("✔ Features nível espécie (bruto): %d\n",
            n_distinct(species_maaslin$tax_id)))

# ── 9.1b  Matriz wide: amostras × espécies ─────────────────────────────────

maaslin_features <- species_maaslin %>%
  pivot_wider(names_from = tax_id, values_from = count, values_fill = 0) %>%
  column_to_rownames("sample_id") %>%
  as.data.frame()

# ── 9.1c  DIAGNÓSTICO DE PREVALÊNCIA ───────────────────────────────────────
#          (mostra por que filtrar é essencial)

n_samples_total <- nrow(maaslin_features)
prev_per_feat   <- colMeans(maaslin_features > 0)

cat(sprintf("\n── Distribuição de Prevalência (%d amostras) ─────────────────\n",
            n_samples_total))
cat(sprintf("  Total features espécie : %5d\n", ncol(maaslin_features)))
cat(sprintf("  Prevalência >=  1%%    : %5d\n", sum(prev_per_feat >= 0.01)))
cat(sprintf("  Prevalência >=  5%%    : %5d\n", sum(prev_per_feat >= 0.05)))
cat(sprintf("  Prevalência >= 10%%    : %5d\n", sum(prev_per_feat >= 0.10)))
cat(sprintf("  Prevalência >= 20%%    : %5d\n", sum(prev_per_feat >= 0.20)))
cat(sprintf("  Prevalência >= 50%%    : %5d\n", sum(prev_per_feat >= 0.50)))
cat("─────────────────────────────────────────────────────────────\n")

# ── 9.1d  PRÉ-FILTRO DE PREVALÊNCIA ────────────────────────────────────────
# Reduz testes múltiplos → melhora poder estatístico drasticamente
# Ajuste min_prev_threshold se necessário (0.10 = default MaAsLin2)

min_prev_threshold <- 0.10

keep_feat <- names(prev_per_feat[prev_per_feat >= min_prev_threshold])
maaslin_features_filt <- maaslin_features[, keep_feat, drop = FALSE]

cat(sprintf("\n✔ Pré-filtro prevalência >= %.0f%%: %d → %d features (removidas %d)\n",
            min_prev_threshold * 100,
            ncol(maaslin_features),
            ncol(maaslin_features_filt),
            ncol(maaslin_features) - ncol(maaslin_features_filt)))

if (ncol(maaslin_features_filt) == 0) {
  stop("❌ Nenhuma feature passou no filtro de prevalência! Reduza min_prev_threshold.")
}

# ── 9.1e  Metadata ─────────────────────────────────────────────────────────

maaslin_meta <- metadata_filtrado %>%
  select(sample_id, treatment) %>%
  column_to_rownames("sample_id") %>%
  as.data.frame()

# ── 9.1f  Alinhar amostras ─────────────────────────────────────────────────

common_s <- intersect(rownames(maaslin_features_filt), rownames(maaslin_meta))
maaslin_features_filt <- maaslin_features_filt[common_s, , drop = FALSE]
maaslin_meta          <- maaslin_meta[common_s, , drop = FALSE]

ref_group        <- "control"
comparison_group <- setdiff(unique(maaslin_meta$treatment), ref_group)

cat(sprintf("✔ Input final: %d amostras × %d features\n",
            nrow(maaslin_features_filt), ncol(maaslin_features_filt)))
cat(sprintf("  Referência : %s\n  Comparação : %s\n",
            ref_group, comparison_group))
cat(sprintf("  Amostras por grupo:\n"))
print(table(maaslin_meta$treatment))

# ─────────────────────────────────────────────────────────────────────────────
# 9.2  Rodar MaAsLin2 — CLR + NONE  (recomendação do colega)
# ─────────────────────────────────────────────────────────────────────────────

maaslin_output_dir <- "maaslin2_output_clr"

set.seed(42)
maaslin_fit <- Maaslin2(
  input_data       = maaslin_features_filt,
  input_metadata   = maaslin_meta,
  output           = maaslin_output_dir,
  fixed_effects    = "treatment",
  reference        = "treatment,control",   # formato: "variável,referência"
  normalization    = "CLR",                 # Centered Log-Ratio (composicional)
  transform        = "NONE",               # CLR já é log-based → sem transform
  analysis_method  = "LM",
  max_significance = 1,                    # retornar TODOS os resultados
  correction       = "BH",
  standardize      = FALSE,
  plot_heatmap     = FALSE,
  plot_scatter     = FALSE,
  max_pngs         = 100,
  cores            = 1
)

cat(sprintf("\n✔ MaAsLin2 (CLR) completo. Output: %s/\n", maaslin_output_dir))

# ─────────────────────────────────────────────────────────────────────────────
# 9.3  Processar resultados
# ─────────────────────────────────────────────────────────────────────────────

q_threshold <- 0.25   # Padrão MaAsLin2; use 0.05 para mais restritivo

maaslin_res <- maaslin_fit$results %>%
  as_tibble() %>%
  filter(metadata == "treatment") %>%
  arrange(qval, pval) %>%
  mutate(
    # Label legível: "Genus Species" em vez de "Genus|Species"
    feature_clean = str_replace(feature, "\\|", " "),
    qval_safe     = pmax(qval, 1e-10),
    neg_log10_q   = -log10(qval_safe),
    neg_log10_p   = -log10(pmax(pval, 1e-10)),
    Direction     = case_when(
      qval < q_threshold & coef > 0 ~
        paste("Enriched in", comparison_group),
      qval < q_threshold & coef < 0 ~
        paste("Enriched in", ref_group),
      TRUE ~ "Not significant"
    )
  )

# Contagens
n_tested   <- nrow(maaslin_res)
n_sig_25   <- sum(maaslin_res$qval < 0.25, na.rm = TRUE)
n_sig_10   <- sum(maaslin_res$qval < 0.10, na.rm = TRUE)
n_sig_05   <- sum(maaslin_res$qval < 0.05, na.rm = TRUE)
n_enr_comp <- sum(maaslin_res$qval < q_threshold &
                    maaslin_res$coef > 0, na.rm = TRUE)
n_enr_ref  <- sum(maaslin_res$qval < q_threshold &
                    maaslin_res$coef < 0, na.rm = TRUE)

cat(sprintf("\n── Resultados ──────────────────────────────\n"))
