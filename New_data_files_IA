  bar_fill_var <- "Direction"
  
} else {
  
  # ── Cenário B: nenhuma significativa → top por p nominal (exploratório) ──
  
  top_features_bar <- maaslin_res %>%
    arrange(pval) %>%
    head(n_top_bar) %>%
    mutate(
      Direction_nominal = case_when(
        coef > 0 ~ paste("Higher in", comparison_group),
        coef < 0 ~ paste("Higher in", ref_group),
        TRUE     ~ "No difference"
      ),
      feature_clean = fct_reorder(feature_clean, coef)
    )
  
  bar_title    <- sprintf("Top %d Species by Nominal p-value (EXPLORATORY)",
                          nrow(top_features_bar))
  bar_subtitle <- paste0(
    "MaAsLin2 \u00B7 CLR \u00B7 ",
    "\u26A0 Not FDR-significant \u2014 hypothesis generation only")
  bar_fill_col <- c(
    setNames(group_colors[comparison_group],
             paste("Higher in", comparison_group)),
    setNames(group_colors[ref_group],
             paste("Higher in", ref_group)),
    "No difference" = "grey72"
  )
  bar_fill_var <- "Direction_nominal"
}

